# App
NODE_ENV=development
PORT=3000

# Local Docker DB (app connects here)
DB_HOST=localhost
DB_PORT=3307
DB_USER=dispatch
DB_PASSWORD=dispatch123
DB_NAME=dispatch_mind_ai

# Source DB — stage1_shopuplite (used only by npm run db:sync)
STAGE_DB_HOST=
STAGE_DB_PORT=3306
STAGE_DB_USER=
STAGE_DB_PASSWORD=
STAGE_DB_NAME=stage1_shopuplite

# AI
ANTHROPIC_API_KEY=

# Auth (optional — no auth endpoints currently use this)
JWT_SECRET=

# CORS — set to your Vercel frontend URL in production (e.g. https://dispatchmindai.vercel.app)
FRONTEND_URL=

# Metabase (optional — needed for metabase integration)
METABASE_SESSION_TOKEN=
METABASE_USER=
METABASE_PASS=

# Logging
LOG_LEVEL=debug
